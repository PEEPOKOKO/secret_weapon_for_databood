create view join_view as 
select account.account_number , account.branch_name , account.balance , customer.customer_name 
from account inner join depositor on account.account_number = depositor.account_number 
inner join customer on customer.customer_name = depositor.customer_name 
where account.branch_name = 'SUT' 
order by account.account_number   ; 

#  2 : select * from join_view 


create view account_view as 
select * from account 
where account.balance < 200
with check option ; 

